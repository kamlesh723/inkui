{
  "name": "@inkui-cli/cli",
  "version": "0.3.1",
  "type": "module",
  "description": "shadcn-style CLI installer for InkUI terminal components",
  "bin": {
    "inkui": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo": "tsx src/cli.tsx list",
    "demo:add": "tsx src/cli.tsx add spinner",
    "demo:playground": "tsx src/cli.tsx playground",
    "test": "echo 'no tests for CLI app'"
  },
  "dependencies": {
    "@inkui-cli/core": "workspace:*",
    "@inkui-cli/panel": "workspace:*",
    "@inkui-cli/spinner": "workspace:*",
    "@inkui-cli/badge": "workspace:*",
    "@inkui-cli/progress-bar": "workspace:*",
    "@inkui-cli/text-input": "workspace:*",
    "@inkui-cli/select": "workspace:*",
    "@inkui-cli/multi-select": "workspace:*",
    "@inkui-cli/table": "workspace:*",
    "@inkui-cli/dialog": "workspace:*",
    "@inkui-cli/toast": "workspace:*",
    "@inkui-cli/status-indicator": "workspace:*",
    "@inkui-cli/loading-bar": "workspace:*",
    "@inkui-cli/confirm": "workspace:*",
    "@inkui-cli/key-hint": "workspace:*",
    "@inkui-cli/divider": "workspace:*",
    "@inkui-cli/header": "workspace:*",
    "string-width": "^7.0.0",
    "ink": "^6.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0"
  }
}
