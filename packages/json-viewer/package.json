{
  "name": "@inkui-cli/json-viewer",
  "version": "0.1.0",
  "description": "Interactive JSON explorer with collapsible nodes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "demo": "tsx demo/index.tsx"
  },
  "peerDependencies": { "ink": "^6.0.0", "react": "^19.0.0" },
  "devDependencies": {
    "@inkui-cli/core": "workspace:*",
    "ink": "^6.0.0",
    "ink-testing-library": "^4.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
